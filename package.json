{
  "name": "images-to-epub",
  "version": "2.0.0",
  "description": "Convert folders of images to EPUB files using Bun + OpenTUI",
  "module": "src/index.ts",
  "type": "module",
  "scripts": {
    "start": "bun run src/index.tsx",
    "dev": "bun run --watch src/index.tsx",
    "test": "bun test",
    "test:watch": "bun test --watch",
    "build": "bun build src/index.tsx --outdir dist --target bun",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@opentui/react": "^0.2.15",
    "i18next": "^26.2.0",
    "jszip": "^3.10.1",
    "react": "^19.0.0",
    "sharp": "^0.34.1",
    "uuid": "^11.1.0",
    "yauzl": "^2.10.0",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/react": "^19.0.0",
    "@types/uuid": "^10.0.0",
    "@types/yauzl": "^2.10.0",
    "typescript": "^5.8.0"
  },
  "peerDependencies": {
    "typescript": "^5.0.0"
  }
}
