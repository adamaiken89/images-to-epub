{
  "name": "images-to-epub",
  "version": "2.0.0",
  "description": "Convert folders of images to EPUB files using Bun + OpenTUI",
  "module": "src/index.tsx",
  "type": "module",
  "scripts": {
    "start": "bun run src/index.tsx",
    "dev": "bun run --watch src/index.tsx",
    "test": "bun test",
    "test:watch": "bun test --watch",
    "test:coverage": "bun test --coverage --coverage-reporter=lcov",
    "build": "bun build src/index.tsx --outdir dist --target bun",
    "lint": "tsc --noEmit && eslint src/ tests/",
    "lint:eslint": "eslint src/ tests/",
    "knip": "knip-bun",
    "format": "prettier --write \"src/**/*.{ts,tsx}\" \"tests/**/*.{ts,tsx}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx}\" \"tests/**/*.{ts,tsx}\"",
    "prepare": "husky"
  },
  "dependencies": {
    "@opentui/react": "^0.2.15",
    "i18next": "^26.2.0",
    "jszip": "^3.10.1",
    "react": "^19.0.0",
    "sharp": "^0.34.1",
    "uuid": "^11.1.0",
    "yauzl": "^2.10.0",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/react": "^19.0.0",
    "@types/uuid": "^10.0.0",
    "@types/yauzl": "^2.10.0",
    "@wyattjoh/opentui-testing": "^1.0.1",
    "eslint": "^10.4.0",
    "eslint-plugin-simple-import-sort": "^13.0.0",
    "husky": "^9.1.7",
    "knip": "^6.14.2",
    "lint-staged": "^17.0.5",
    "prettier": "^3.8.3",
    "typescript": "^5.8.0",
    "typescript-eslint": "^8.59.4"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.json": [
      "prettier --write"
    ]
  },
  "peerDependencies": {
    "typescript": "^5.0.0"
  }
}
