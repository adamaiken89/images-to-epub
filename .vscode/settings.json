{
  "python.linting.enabled": true,
  "python.linting.pylintEnabled": false,
  "python.languageServer": "None",
  "basedpyright.typeCheckingMode": "basic",
  "basedpyright.reportMissingImports": true,
  "basedpyright.reportMissingTypeStubs": false,
  "basedpyright.reportUnusedImport": true,
  "basedpyright.reportUnusedVariable": true,
  "basedpyright.reportUnusedFunction": true,
  "basedpyright.reportUnusedClass": true,
  "python.analysis.typeCheckingMode": "basic",
  "python.analysis.autoImportCompletions": true,
  "python.analysis.diagnosticMode": "workspace",
  "cSpell.words": [
    "columnspan",
    "epubenv",
    "padx",
    "pady",
    "pycache",
    "scrollregion",
    "subfolders",
    "tkfont",
    "Tkinter",
    "venv",
    "xscrollcommand",
    "yscrollcommand"
  ]
}
